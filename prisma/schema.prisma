// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  STARTER
  PREMIUM
}

model User {
  id             String          @id
  name           String
  email          String
  emailVerified  Boolean
  image          String?
  createdAt      DateTime
  updatedAt      DateTime
  role           ROLE            @default(STARTER)
  apiKey         ApiKey[]
  sessions       Session[]
  accounts       Account[]
  playerAccounts PlayerAccount[]
  accountDevice  AccountDevice[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

enum PLAYERACCOUNT_STATUS {
  ONLINE
  OFFLINE
}

model AccountDevice {
  id             String          @id @default(cuid())
  name           String
  playerAccounts PlayerAccount[]

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerAccount {
  id            String               @id @default(cuid())
  account       String
  device        AccountDevice        @relation(fields: [accountDeviceId], references: [id])
  potions       Int                  @default(0)
  bucks         Int                  @default(0)
  eventCurrency Int                  @default(0)
  tickets       Int                  @default(0)
  lastSeen      DateTime?
  upTime        DateTime?
  status        PLAYERACCOUNT_STATUS @default(ONLINE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  items           Item[]
  user            User?   @relation(fields: [userId], references: [id])
  userId          String?
  apiKey          ApiKey? @relation(fields: [apiKeyId], references: [id])
  apiKeyId        String?
  accountDeviceId String

  @@map("player_account")
}

model Item {
  id              String        @id @default(cuid())
  playerAccountId String
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id], onDelete: Cascade)

  type           ItemType
  name           String
  quantity       Int      @default(1)
  thumbnailImage String?

  pet Pet?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("item")
}

enum PETRARITY {
  LEGENDARY
  ULTRA_RARE
  RARE
  UNCOMMON
  COMMON
}

model Pet {
  id     String    @id @default(cuid())
  itemId String    @unique
  item   Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  rarity PETRARITY
  age    Int       @default(1)

  variant PetVariant
  potion  PetPotion

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pet")
}

model ApiKey {
  id             String          @id @default(cuid())
  key            String          @unique
  maxRequests    Int
  requestsUsed   Int             @default(0)
  playerAccounts PlayerAccount[]

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  lastUsedAt DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_key")
}

enum PetVariant {
  NORMAL
  NEON
  MEGA
}

enum PetPotion {
  NONE
  RIDE
  FLY
  FLY_RIDE
}

enum ItemType {
  PET
  PET_WEAR
  FOOD
}
